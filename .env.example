# Frontend public URLs (embedded at build time)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend internal URL (used by Next.js server-side inside Docker)
# Change to http://localhost:4000/api when running outside Docker
BACKEND_INTERNAL_URL=http://backend:4000/api

# JWT secret — change before deploying
JWT_SECRET=change-me-in-production

# Frontend URL (used by backend for CORS allow-list)
FRONTEND_URL=http://localhost:3000

# ── AI Features ───────────────────────────────────────────────────────────────
# Required for AI agents (prioritization, decomposition, standup, card chat)
OPENAI_API_KEY=sk-...
# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
